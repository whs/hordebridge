// KoboldCppAutomatic syntax

{
package koboldcpp

import (
	"github.com/openai/openai-go/v3/responses"
)
}

Prompt = (role:Role / message:.)*

Role = SystemRole / UserRole / AssistantRole
SystemRole = "{{[SYSTEM]}}" { return responses.EasyInputMessageRoleSystem, nil }
UserRole = ("{{[INPUT]}}" / ("\n"? "### Instruction:\n")) { return responses.EasyInputMessageRoleUser, nil }
AssistantRole = ("{{[OUTPUT]}}" / ("\n"? "### Response:\n")) { return responses.EasyInputMessageRoleAssistant, nil }